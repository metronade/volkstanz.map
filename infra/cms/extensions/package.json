{
  "name": "volkstanz-extensions",
  "version": "1.0.0",
  "type": "module",
  "directus:extension": {
    "type": "pack",
    "path": {
      "app": "dist/index.js",
      "api": "dist/index.js"
    },
    "entries": [
      { "name": "coords", "source": "endpoints/coords/index.ts" },
      { "name": "stats",  "source": "endpoints/stats/index.ts" }
