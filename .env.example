# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Volkstanz-Map – .env.example  →  kopieren nach .env und ausfüllen     ║
# ║  Backend: Payload CMS 3 (Node.js)                                       ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Externer Zugriff ────────────────────────────────────────────────────
PUBLIC_URL_BASE=https://volkstanz.example.org
EXPOSED_PORT=80

# Lokaler Test: PUBLIC_URL_BASE kann leer bleiben oder http://localhost sein.

# ── Dynamischer Admin-Pfad ──────────────────────────────────────────────
# Unter diesem Pfad hängt das Payload-Admin-UI.
ADMIN_PATH=/verwaltung

# Optional: Cookie-Domain (z. B. .example.org für alle Subdomains)
COOKIE_DOMAIN=

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=volkstanz
POSTGRES_PASSWORD=__CHANGE_ME__use_openssl_rand_hex_24__
POSTGRES_DB=volkstanz

# ── Payload-Secret ──────────────────────────────────────────────────────
# 32+ Zeichen Zufallsstring (openssl rand -hex 24)
PAYLOAD_SECRET=__CHANGE_ME__use_openssl_rand_hex_24__

# ── Initialer Admin-Account ─────────────────────────────────────────────
# Wird vom Seed-Skript beim ersten Start angelegt.
INITIAL_ADMIN_NAME=Administrator
INITIAL_ADMIN_EMAIL=admin@example.org
INITIAL_ADMIN_PASSWORD=__CHANGE_ME__

# ── Login-Sicherheit ────────────────────────────────────────────────────
AUTH_LOCK_TIME=900
AUTH_MAX_LOGIN_ATTEMPTS=5

# ── Rate-Limiter ────────────────────────────────────────────────────────
# X Requests innerhalb von Y Sekunden pro IP
RATE_LIMITER_POINTS=500
RATE_LIMITER_DURATION=60

# ── TOTP ────────────────────────────────────────────────────────────────
TOTP_ISSUER=Volkstanz·Map
