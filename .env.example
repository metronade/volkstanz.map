# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Volkstanz-Map – .env.example  →  kopieren nach .env und ausfüllen     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Externer Zugriff ────────────────────────────────────────────────────
# Basis-URL der öffentlichen Installation (ohne trailing slash)
PUBLIC_URL_BASE=https://volkstanz.example.org
# Port, den der externe Nginx Proxy Manager anspricht (Container-intern: 80)
EXPOSED_PORT=80

# ── Dynamischer Admin-Pfad ──────────────────────────────────────────────
# Unter diesem Pfad hängt das Directus-Admin-UI – NICHT /admin hartcodiert!
ADMIN_PATH=/verwaltung

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=volkstanz
# Bitte 32+ Zeichen Zufallsstring (z. B. `openssl rand -hex 24`)
POSTGRES_PASSWORD=__CHANGE_ME__use_openssl_rand_hex_24__
POSTGRES_DB=volkstanz

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=__CHANGE_ME__use_openssl_rand_hex_24__

# ── Directus Secrets ────────────────────────────────────────────────────
DIRECTUS_SECRET=__CHANGE_ME__use_openssl_rand_hex_24__
DIRECTUS_KEY=__CHANGE_ME__use_openssl_rand_hex_24__

# Initialer Admin-Account (nach erstem Login ändern & 2FA aktivieren!)
DIRECTUS_ADMIN_EMAIL=admin@example.org
DIRECTUS_ADMIN_PASSWORD=__CHANGE_ME__

# ── Rate-Limiter ────────────────────────────────────────────────────────
# X Requests innerhalb von Y Sekunden pro IP
# Achtung: Directus' Admin-UI lädt dutzende JS/CSS/Font-Assets beim ersten
# Seitenaufruf — 10 req/60s sind zu knapp. Für lokalen Test 500+, für
# Produktion anhand der erwarteten Besucherspitze wählen.
RATE_LIMITER_POINTS=500
RATE_LIMITER_DURATION=60

# ── Login-Sicherheit ────────────────────────────────────────────────────
# Account-Sperre nach N Fehlversuchen (Sekunden)
AUTH_LOCK_TIME=900
AUTH_MAX_LOGIN_ATTEMPTS=5

# ── E-Mail (optional) ───────────────────────────────────────────────────
# sendmail | smtp | mailgun | …  – siehe Directus-Doku
EMAIL_TRANSPORT=sendmail
