---
import Base from '@layouts/Base.astro';
import Map from '@components/Map.astro';
import SearchBar from '@components/SearchBar.astro';
import CompassRose from '@components/CompassRose.astro';
import { t, localeFromPath, type Locale, localizedPath } from '@i18n/index';
import { directusGet } from '@lib/directus';

const locale: Locale = localeFromPath(Astro.url.pathname);

// Statistik-Zahlen für den Hero-Bereich
const stats = await directusGet<{ data: { groups: number; countries: number }[] }>(
  '/custom/stats/summary',
  {},
);
const groupsCount = stats?.data?.[0]?.groups ?? 0;
const countriesCount = stats?.data?.[0]?.countries ?? 0;
---

<Base>
  <!-- ╔══ Hero ════════════════════════════════════════════════════╗ -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="pill pill--accent hero__eyebrow">{t('brand.tagline', locale)}</span>
        <h1 class="hero__title">{t('home.hero.title', locale)}</h1>
        <p class="hero__subtitle">{t('home.hero.subtitle', locale)}</p>
        <div class="hero__cta">
          <a href="#map" class="btn btn--primary">{t('home.hero.cta.explore', locale)}</a>
          <a href={localizedPath('gruppe-eintragen', locale)} class="btn">{t('home.hero.cta.submit', locale)}</a>
        </div>

        <dl class="hero__stats">
          <div>
            <dt>{t('home.stats.groups', locale)}</dt>
            <dd>{groupsCount || '—'}</dd>
          </div>
          <div>
            <dt>{t('home.stats.countries', locale)}</dt>
            <dd>{countriesCount || '—'}</dd>
          </div>
        </dl>
      </div>
      <div class="hero__compass" aria-hidden="true">
        <CompassRose size={320} opacity={0.9} />
      </div>
    </div>
  </section>

  <!-- ╔══ Karte ═══════════════════════════════════════════════════╗ -->
  <section id="map" class="map-section">
    <div class="container">
      <header class="section-head">
        <h2 class="section-head__title">
          {locale === 'de' ? 'Die Karte' : 'The Map'}
        </h2>
        <p class="section-head__sub">
          {locale === 'de'
            ? 'Klicken Sie auf eine Windrose, um mehr zu erfahren.'
            : 'Click on a wind rose to learn more.'}
        </p>
      </header>

      <div class="map-wrap">
        <SearchBar />
        <Map height="640px" />
      </div>

      <p class="map-attribution">
        <small>
          © OpenStreetMap-Mitwirkende · Koordinaten aus Datenschutzgründen gerundet.
        </small>
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-8) var(--space-7);
    background:
      radial-gradient(ellipse at top right, rgba(176, 138, 62, 0.07), transparent 60%),
      var(--paper-base);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .hero__eyebrow { margin-bottom: var(--space-4); }

  .hero__title {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    margin-bottom: var(--space-4);
    font-weight: 700;
  }

  .hero__subtitle {
    font-size: var(--fs-md);
    line-height: var(--lh-loose);
    color: var(--ink-secondary);
    font-family: var(--font-display);
    font-style: italic;
    max-width: 38ch;
    margin-bottom: var(--space-6);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-7);
  }

  .hero__stats {
    display: flex;
    gap: var(--space-7);
    border-top: 1px solid var(--line-hair);
    padding-top: var(--space-5);
    margin: 0;
  }

  .hero__stats dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: var(--space-1);
  }

  .hero__stats dd {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    margin: 0;
  }

  .hero__compass {
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--ink-primary);
    position: relative;
  }

  .hero__compass::after {
    content: '';
    position: absolute;
    inset: -10%;
    background: radial-gradient(circle, rgba(176, 138, 62, 0.08), transparent 60%);
    z-index: -1;
  }

  .section-head {
    text-align: center;
    margin-bottom: var(--space-6);
  }
  .section-head__title {
    font-size: var(--fs-2xl);
    margin-bottom: var(--space-2);
  }
  .section-head__sub {
    color: var(--ink-muted);
    font-style: italic;
    font-family: var(--font-display);
    font-size: var(--fs-md);
  }

  .map-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .map-attribution {
    margin-top: var(--space-3);
    text-align: center;
    color: var(--ink-muted);
  }

  @media (max-width: 880px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__compass { order: -1; transform: scale(0.7); }
    .hero__title { font-size: var(--fs-2xl); }
    .hero__stats { gap: var(--space-5); flex-wrap: wrap; }
  }
</style>
