---
import Base from '@layouts/Base.astro';
import CompassRose from '@components/CompassRose.astro';
import { t, localeFromPath, type Locale, localizedPath } from '@i18n/index';

const locale: Locale = localeFromPath(Astro.url.pathname);
---

<Base title={t('about.title', locale)}>
  <article class="about">
    <div class="container container--narrow">
      <header class="about__head">
        <span class="pill pill--accent">{locale === 'de' ? 'Manifest' : 'Manifesto'}</span>
        <h1 class="about__title">{t('about.title', locale)}</h1>
        <p class="about__lead">{t('about.lead', locale)}</p>
      </header>

      <div class="about__compass">
        <CompassRose size={160} opacity={0.7} />
      </div>

      <section class="about__section">
        <h2>{t('about.section.mission.title', locale)}</h2>
        <p>{t('about.section.mission.body', locale)}</p>
      </section>

      <section class="about__section">
        <h2>{t('about.section.privacy.title', locale)}</h2>
        <p>{t('about.section.privacy.body', locale)}</p>
      </section>

      <section class="about__section">
        <h2>{t('about.section.consent.title', locale)}</h2>
        <p>{t('about.section.consent.body', locale)}</p>
      </section>

      <hr />

      <p class="about__cta">
        <a class="btn btn--primary" href={localizedPath('gruppe-eintragen', locale)}>
          {t('home.hero.cta.submit', locale)}
        </a>
        <a class="btn" href={localizedPath('', locale)}>
          {t('home.hero.cta.explore', locale)}
        </a>
      </p>
    </div>
  </article>
</Base>

<style>
  .about { padding-block: var(--space-8) var(--space-7); }

  .about__head { text-align: center; margin-bottom: var(--space-7); }

  .about__title {
    font-size: var(--fs-3xl);
    margin: var(--space-3) 0 var(--space-4);
  }

  .about__lead {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-style: italic;
    color: var(--ink-secondary);
    max-width: 32ch;
    margin-inline: auto;
    line-height: var(--lh-loose);
  }

  .about__compass {
    display: flex;
    justify-content: center;
    margin: var(--space-6) 0;
    color: var(--accent-gold-d);
  }

  .about__section {
    margin-bottom: var(--space-6);
  }
  .about__section h2 {
    font-size: var(--fs-xl);
    margin-bottom: var(--space-3);
    color: var(--accent-forest);
  }
  .about__section p {
    font-size: var(--fs-md);
    line-height: var(--lh-loose);
    color: var(--ink-secondary);
  }

  .about__cta {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
