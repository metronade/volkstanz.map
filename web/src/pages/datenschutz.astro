---
import Base from '@layouts/Base.astro';
import { payloadGet, type PayloadResult, type ContentEntry } from '@lib/payload';
import { localeFromPath, type Locale } from '@i18n/index';
import { renderMarkdown, richTextToMarkdown } from '@lib/markdown';

const locale: Locale = localeFromPath(Astro.url.pathname);

const content = await payloadGet<PayloadResult<ContentEntry>>('/api/content', {
  where: JSON.stringify({ key: { equals: 'legal.privacy' } }),
  limit: '1',
});
const entry = content?.docs?.[0];
const translation = entry?.translations?.find((t) => t.lang === locale);

const fallbackDe = `# Datenschutzerklärung

## 1. Verantwortlicher
[Vollständiger Name, Anschrift, E-Mail]

## 2. Verarbeitete Daten
- **Gruppen-Daten** (Name, Ort, Kontakt): Veröffentlichung auf Grundlage Ihrer Einwilligung (Art. 6 Abs. 1 lit. a DSGVO).
- **IP-Adressen**: Speicherung als anonymisierter SHA-256-Hash (täglich wechselnder Salt) zur Betrugserkennung (Art. 6 Abs. 1 lit. f DSGVO).
- **Bilder**: Nur mit ausdrücklicher Einwilligung aller abgebildeten Personen (§ 22 KUG).

## 3. Cookies
Diese Seite verwendet ausschließlich **technisch notwendige** Cookies (Session, Sprache). Es findet **keine** Weitergabe an Dritte statt.

## 4. Ihre Rechte
Auskunft, Berichtigung, Löschung, Einschränkung, Datenübertragbarkeit, Widerspruch. Beschwerderecht bei der Aufsichtsbehörde.

## 5. Speicherdauer
Einwilligungsgebundene Daten werden bis zum Widerruf gespeichert; anonymisierte Hash-Werte 90 Tage.

## 6. Kontakt
Anfragen zum Datenschutz: [E-Mail]`;

const fallbackEn = `# Privacy Policy

## 1. Controller
[Full name, address, email]

## 2. Data processed
- **Group data** (name, location, contact): published based on your consent (Art. 6 (1) lit. a GDPR).
- **IP addresses**: stored as anonymized SHA-256 hash (daily-rotating salt) for fraud detection (Art. 6 (1) lit. f GDPR).
- **Images**: only with explicit consent of all depicted persons (§ 22 KUG).

## 3. Cookies
This site uses exclusively **technically necessary** cookies (session, language). **No** data is shared with third parties.

## 4. Your rights
Access, rectification, erasure, restriction, portability, objection. Right to lodge a complaint with a supervisory authority.

## 5. Retention
Consent-based data is stored until withdrawal; anonymized hash values 90 days.

## 6. Contact
Privacy inquiries: [email]`;

const body = translation?.body
  ? richTextToMarkdown(translation.body)
  : (locale === 'en' ? fallbackEn : fallbackDe);

const html = renderMarkdown(body);
---

<Base title={locale === 'de' ? 'Datenschutz' : 'Privacy'}>
  <article class="legal">
    <div class="container container--narrow">
      <h1>{locale === 'de' ? 'Datenschutz' : 'Privacy'}</h1>
      <div class="legal__body" set:html={html} />
    </div>
  </article>
</Base>

<style>
  .legal { padding-block: var(--space-8) var(--space-7); }
  .legal h1 { font-size: var(--fs-3xl); margin-bottom: var(--space-5); }
  .legal__body { line-height: var(--lh-loose); color: var(--ink-secondary); }
  .legal__body :global(h1) { display: none; }
  .legal__body :global(h2) {
    font-family: var(--font-display);
    color: var(--ink-primary);
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
    font-size: var(--fs-lg);
  }
  .legal__body :global(p) { margin-bottom: var(--space-3); }
</style>
