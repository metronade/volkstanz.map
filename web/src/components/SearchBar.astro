---
import { t, localeFromPath, type Locale } from '@i18n/index';
const locale: Locale = localeFromPath(Astro.url.pathname);
---

<form class="search" role="search" data-search-form>
  <label class="search__label">
    <span class="sr-only">{t('search.placeholder', locale)}</span>
    <input
      type="search"
      class="search__input"
      placeholder={t('search.placeholder', locale)}
      autocomplete="off"
      data-search-input
    />
  </label>
  <button type="submit" class="search__btn">{t('search.button', locale)}</button>
  <p class="search__result-meta" data-search-meta aria-live="polite"></p>
</form>

<style>
  .search {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: stretch;
  }

  .search__label {
    flex: 1 1 280px;
    margin: 0;
  }

  .search__input {
    height: 100%;
    border-right: none;
    border-color: var(--line-emphasis);
    background: var(--paper-base);
  }

  .search__input:focus {
    box-shadow: none;
  }

  .search__btn {
    padding-inline: var(--space-5);
    background: var(--ink-primary);
    color: var(--paper-base);
    border: 1px solid var(--ink-primary);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    transition: background var(--duration-fast) var(--ease-paper);
  }

  .search__btn:hover {
    background: var(--accent-wine);
    border-color: var(--accent-wine);
  }

  .search__result-meta {
    flex: 1 0 100%;
    margin-top: var(--space-2);
    color: var(--ink-muted);
    font-size: var(--fs-sm);
    font-family: var(--font-mono);
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
